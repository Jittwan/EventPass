# Local development (SQLite). Override with a Postgres URL for Vercel.
# Example for Vercel Postgres / Supabase / Neon:
#   DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_URL="file:./dev.db"

# Admin credentials (used by /admin/login)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"

# Used to sign admin session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="please-replace-with-a-long-random-string-min-32-chars"
